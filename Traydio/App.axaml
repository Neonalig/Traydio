<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="Traydio.App"
             xmlns:local="using:Traydio"
             RequestedThemeVariant="Light">

    <Application.DataTemplates>
        <local:ViewLocator/>
    </Application.DataTemplates>
  
    <Application.Styles>
        <ClassicTheme />
        <StyleInclude Source="avares://Traydio/Styles/ThemeTokens.axaml"/>
        <StyleInclude Source="avares://Traydio/Styles/ControlStyles.axaml"/>
        <StyleInclude Source="avares://Classic.Avalonia.Theme.DataGrid/Classic.axaml"/>
    </Application.Styles>
</Application>