<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Style Selector="Window">
        <Setter Property="Padding" Value="{DynamicResource AppWindowPadding}"/>
        <Setter Property="FontFamily" Value="Tahoma"/>
        <Setter Property="FontSize" Value="12"/>
    </Style>

    <Style Selector="UserControl">
        <Setter Property="FontFamily" Value="Tahoma"/>
        <Setter Property="FontSize" Value="12"/>
    </Style>

    <Style Selector="TextBlock.section-title">
        <Setter Property="FontSize" Value="{DynamicResource SectionTitleSize}"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
    </Style>

    <Style Selector="TextBlock.subtle-text">
        <Setter Property="Foreground" Value="{DynamicResource MutedForegroundBrush}"/>
    </Style>

    <Style Selector="TextBlock.helper-text">
        <Setter Property="Foreground" Value="{DynamicResource MutedForegroundBrush}"/>
        <Setter Property="TextWrapping" Value="Wrap"/>
    </Style>


    <Style Selector="TextBlock.error-text">
        <Setter Property="Foreground" Value="{DynamicResource StatusErrorBrush}"/>
    </Style>

    <Style Selector="TextBlock.accent-text">
        <Setter Property="Foreground" Value="{DynamicResource StatusAccentBrush}"/>
    </Style>

    <Style Selector="Border.surface-card">
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="BorderBrush" Value="{DynamicResource SurfaceBorderBrush}"/>
        <Setter Property="Padding" Value="{DynamicResource SurfacePadding}"/>
        <Setter Property="Margin" Value="{DynamicResource SurfaceMargin}"/>
    </Style>

    <Style Selector="Border.toolbar-frame">
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="BorderBrush" Value="{DynamicResource SurfaceBorderBrush}"/>
        <Setter Property="Padding" Value="{DynamicResource SurfacePadding}"/>
        <Setter Property="Margin" Value="{DynamicResource SurfaceMargin}"/>
        <Setter Property="Background" Value="{DynamicResource ToolbarBackgroundBrush}"/>
    </Style>

    <Style Selector="Button.toolbar-button">
        <Setter Property="MinWidth" Value="130"/>
        <Setter Property="Padding" Value="6,3"/>
        <Setter Property="HorizontalContentAlignment" Value="Left"/>
    </Style>

    <Style Selector="Button.ribbon-button">
        <Setter Property="MinWidth" Value="88"/>
        <Setter Property="Width" Value="88"/>
        <Setter Property="Height" Value="72"/>
        <Setter Property="Padding" Value="6,4"/>
        <Setter Property="HorizontalContentAlignment" Value="Center"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
    </Style>

    <Style Selector="ToggleButton.ribbon-button">
        <Setter Property="MinWidth" Value="88"/>
        <Setter Property="Width" Value="88"/>
        <Setter Property="Height" Value="72"/>
        <Setter Property="Padding" Value="6,4"/>
        <Setter Property="HorizontalContentAlignment" Value="Center"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
    </Style>

    <Style Selector="ToggleButton.ribbon-tab:checked">
        <Setter Property="Background" Value="#FFFFFF"/>
        <Setter Property="BorderBrush" Value="#5A5A5A"/>
    </Style>

    <Style Selector="Border.ribbon-separator">
        <Setter Property="Width" Value="1"/>
        <Setter Property="Margin" Value="2,4"/>
        <Setter Property="Background" Value="{DynamicResource SurfaceBorderBrush}"/>
    </Style>

    <Style Selector="Button.command-button">
        <Setter Property="MinWidth" Value="104"/>
        <Setter Property="Padding" Value="8,3"/>
    </Style>

    <Style Selector="Button.plugin-row-button">
        <Setter Property="MinWidth" Value="92"/>
        <Setter Property="MaxHeight" Value="36"/>
        <Setter Property="Padding" Value="6,3"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
    </Style>

    <Style Selector="Button.icon-only">
        <Setter Property="MinWidth" Value="28"/>
        <Setter Property="Width" Value="28"/>
        <Setter Property="Height" Value="28"/>
        <Setter Property="Padding" Value="4"/>
        <Setter Property="HorizontalContentAlignment" Value="Center"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
    </Style>

    <Style Selector="Border.group-frame">
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="BorderBrush" Value="{DynamicResource SurfaceBorderBrush}"/>
        <Setter Property="Margin" Value="{DynamicResource SurfaceMargin}"/>
        <Setter Property="Padding" Value="{DynamicResource GroupPadding}"/>
    </Style>

    <Style Selector="Border.group-caption-chip">
        <Setter Property="Background" Value="{DynamicResource GroupCaptionBackgroundBrush}"/>
        <Setter Property="Padding" Value="4,0,4,2"/>
        <Setter Property="Margin" Value="10,0,0,0"/>
        <Setter Property="HorizontalAlignment" Value="Left"/>
        <Setter Property="ZIndex" Value="1"/>
    </Style>

    <Style Selector="TextBlock.group-title">
        <Setter Property="Margin" Value="0"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
    </Style>

    <Style Selector="Image.icon-small">
        <Setter Property="Width" Value="16"/>
        <Setter Property="Height" Value="16"/>
    </Style>

    <Style Selector="Image.icon-large">
        <Setter Property="Width" Value="24"/>
        <Setter Property="Height" Value="24"/>
    </Style>

    <Style Selector="Image.icon-ribbon">
        <Setter Property="Width" Value="24"/>
        <Setter Property="Height" Value="24"/>
    </Style>

    <Style Selector="ListBox.list-surface">
        <Setter Property="MinHeight" Value="210"/>
    </Style>

    <Style Selector="ListBox.plugin-list-surface">
        <Setter Property="MinHeight" Value="130"/>
    </Style>

    <Style Selector="Border.station-entry">
        <Setter Property="Padding" Value="4"/>
        <Setter Property="Margin" Value="0,0,0,4"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="BorderBrush" Value="Transparent"/>
    </Style>

    <Style Selector="Border.station-entry.playing-station">
        <Setter Property="Background" Value="#E8F2E8"/>
        <Setter Property="BorderBrush" Value="#2D7A2D"/>
    </Style>

    <Style Selector="Border.station-entry.failed-station">
        <Setter Property="Background" Value="#FBE5E5"/>
        <Setter Property="BorderBrush" Value="#9A2020"/>
    </Style>

    <Style Selector="ListBoxItem:selected Border.station-entry">
        <Setter Property="Background" Value="#1E3E74"/>
        <Setter Property="BorderBrush" Value="#112A4E"/>
    </Style>

    <Style Selector="ListBoxItem:selected Border.station-entry TextBlock">
        <Setter Property="Foreground" Value="#F6F8FF"/>
    </Style>

    <Style Selector="TextBlock.now-playing-badge">
        <Setter Property="Foreground" Value="#1E7E34"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
    </Style>

    <Style Selector="ListBoxItem:selected TextBlock.now-playing-badge">
        <Setter Property="Foreground" Value="#9FF2A6"/>
        <Setter Property="FontWeight" Value="Bold"/>
    </Style>

    <Style Selector="Border.status-strip">
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="BorderBrush" Value="{DynamicResource SurfaceBorderBrush}"/>
        <Setter Property="Padding" Value="{DynamicResource SurfacePadding}"/>
        <Setter Property="Margin" Value="{DynamicResource SurfaceMargin}"/>
        <Setter Property="Background" Value="{DynamicResource StatusBackgroundBrush}"/>
    </Style>

    <Style Selector="Border.tip-help-box">
        <Setter Property="Background" Value="{DynamicResource TipBoxBackgroundBrush}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource TipBoxBorderBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Padding" Value="4,2"/>
        <Setter Property="MinHeight" Value="22"/>
    </Style>

    <Style Selector="TextBox.input-standard">
        <Setter Property="Padding" Value="8,4"/>
        <Setter Property="TextAlignment" Value="Left"/>
        <Setter Property="HorizontalContentAlignment" Value="Left"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
    </Style>

    <Style Selector="TextBox.input-standard /template/ ContentPresenter#PART_WatermarkPresenter">
        <Setter Property="HorizontalAlignment" Value="Left"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
        <Setter Property="Margin" Value="8,0,8,0"/>
        <Setter Property="TextAlignment" Value="Left"/>
    </Style>

    <Style Selector="TextBox.input-standard /template/ TextBlock#PART_WatermarkPresenter">
        <Setter Property="HorizontalAlignment" Value="Left"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
        <Setter Property="Margin" Value="8,0,8,0"/>
        <Setter Property="TextAlignment" Value="Left"/>
    </Style>

    <Style Selector="Border.plugin-candidate-entry">
        <Setter Property="Padding" Value="4"/>
        <Setter Property="Margin" Value="0,0,0,4"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="BorderBrush" Value="Transparent"/>
    </Style>

    <Style Selector="Border.plugin-candidate-entry.recommended-candidate">
        <Setter Property="BorderBrush" Value="#D2A500"/>
        <Setter Property="Background" Value="#20FFE699"/>
    </Style>

    <Style Selector="Border.recommended-badge">
        <Setter Property="Padding" Value="4,1"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="BorderBrush" Value="#CC9A00"/>
        <Setter Property="Background" Value="#FFF5C8"/>
        <Setter Property="CornerRadius" Value="3"/>
        <Setter Property="HorizontalAlignment" Value="Left"/>
    </Style>

    <Style Selector="TextBlock.recommended-badge-text">
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Foreground" Value="#6E5500"/>
        <Setter Property="FontSize" Value="11"/>
    </Style>
</Styles>

