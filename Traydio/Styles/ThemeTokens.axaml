<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Styles.Resources>
        <Thickness x:Key="AppWindowPadding">12</Thickness>
        <Thickness x:Key="SurfacePadding">10</Thickness>
        <Thickness x:Key="SurfaceMargin">6</Thickness>

        <x:Double x:Key="RowGap">10</x:Double>
        <x:Double x:Key="ColumnGap">8</x:Double>
        <x:Double x:Key="SectionTitleSize">15</x:Double>

        <SolidColorBrush x:Key="SurfaceBorderBrush">#7A7A7A</SolidColorBrush>
        <SolidColorBrush x:Key="MutedForegroundBrush">#4A4A4A</SolidColorBrush>
        <SolidColorBrush x:Key="StatusErrorBrush">#9A2020</SolidColorBrush>
        <SolidColorBrush x:Key="StatusAccentBrush">#0B4F7A</SolidColorBrush>
    </Styles.Resources>
</Styles>

