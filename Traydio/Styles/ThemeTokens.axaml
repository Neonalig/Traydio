<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Styles.Resources>
        <Thickness x:Key="AppWindowPadding">8</Thickness>
        <Thickness x:Key="SurfacePadding">8</Thickness>
        <Thickness x:Key="SurfaceMargin">4</Thickness>
        <Thickness x:Key="GroupPadding">10,14,10,10</Thickness>

        <x:Double x:Key="RowGap">8</x:Double>
        <x:Double x:Key="ColumnGap">8</x:Double>
        <x:Double x:Key="SectionTitleSize">14</x:Double>

        <SolidColorBrush x:Key="SurfaceBorderBrush">#7A7A7A</SolidColorBrush>
        <SolidColorBrush x:Key="ToolbarBackgroundBrush">#D4D0C8</SolidColorBrush>
        <SolidColorBrush x:Key="GroupCaptionBackgroundBrush">#D4D0C8</SolidColorBrush>
        <SolidColorBrush x:Key="StatusBackgroundBrush">#D4D0C8</SolidColorBrush>
        <SolidColorBrush x:Key="TipBoxBackgroundBrush">#FFFFE1</SolidColorBrush>
        <SolidColorBrush x:Key="TipBoxBorderBrush">#8A8A57</SolidColorBrush>
        <SolidColorBrush x:Key="MutedForegroundBrush">#353535</SolidColorBrush>
        <SolidColorBrush x:Key="StatusErrorBrush">#9A2020</SolidColorBrush>
        <SolidColorBrush x:Key="StatusAccentBrush">#003C74</SolidColorBrush>
    </Styles.Resources>
</Styles>

