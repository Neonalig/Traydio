<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Traydio.ViewModels"
             xmlns:conv="using:Traydio.Converters"
             xmlns:imaging="clr-namespace:Avalonia.Media.Imaging;assembly=Avalonia.Base"
             x:Class="Traydio.Views.StationManagerPage"
             x:Name="Root"
             x:DataType="vm:StationManagerPageViewModel"
             DragDrop.AllowDrop="True"
             DragDrop.DragOver="OnDragOver"
             DragDrop.Drop="OnDrop">
    <UserControl.Resources>
        <imaging:Bitmap x:Key="PlayIcon">avares://Traydio/Assets/play.ico</imaging:Bitmap>
        <imaging:Bitmap x:Key="PauseIcon">avares://Traydio/Assets/pause.ico</imaging:Bitmap>
        <conv:StationIconConverter x:Key="StationIconConverter" DefaultIcon="/Assets/stations.ico"/>
        <conv:BooleanToImageConverter x:Key="PlayPauseGlyphConverter"
                                      TrueImage="{StaticResource PauseIcon}"
                                      FalseImage="{StaticResource PlayIcon}"/>
    </UserControl.Resources>


    <Grid RowDefinitions="Auto,*" RowSpacing="6" Margin="0">
        <Border Grid.Row="0" Classes="status-strip" Margin="0">
            <TextBlock Text="Tip: press Ctrl+C on a selected station to copy its ID. Right-click a station for copy/open/link command actions." Classes="helper-text"/>
        </Border>

        <Grid Grid.Row="1" RowDefinitions="Auto,*" RowSpacing="0" Margin="4,0,4,4">
            <Border Classes="group-caption-chip">
                <TextBlock Text="Saved Stations" Classes="group-title"/>
            </Border>
            <Border Grid.Row="1" Classes="group-frame" Margin="0,-8,0,0">
                <Grid RowDefinitions="*,Auto" RowSpacing="10">
                    <ListBox Grid.Row="0"
                             x:Name="StationsList"
                             Classes="list-surface"
                             ItemsSource="{Binding Stations}"
                             SelectedItem="{Binding SelectedStation}"
                             SelectionMode="Multiple"
                             KeyDown="OnStationsListKeyDown"
                             DoubleTapped="OnStationsListDoubleTapped">
                        <ListBox.Styles>
                            <Style Selector="ListBoxItem">
                                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                            </Style>
                        </ListBox.Styles>
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border Classes="station-entry"
                                        Classes.playing-station="{Binding IsActivePlaying}"
                                        Classes.failed-station="{Binding IsRecentFailure}"
                                        HorizontalAlignment="Stretch"
                                        Background="Transparent">
                                    <Border.ContextMenu>
                                        <ContextMenu Opened="OnStationContextMenuOpened">
                                            <MenuItem Header="Play" Click="OnPlayStationClick"/>
                                            <MenuItem Header="Delete" Click="OnRemoveStationClick"/>
                                            <Separator/>
                                            <MenuItem x:Name="MoveToTopMenuItem" Header="Move to Top" Click="OnMoveStationToTopClick"/>
                                            <MenuItem x:Name="MoveUpMenuItem" Header="Move Up" Click="OnMoveStationUpClick"/>
                                            <MenuItem x:Name="MoveDownMenuItem" Header="Move Down" Click="OnMoveStationDownClick"/>
                                            <MenuItem x:Name="MoveToBottomMenuItem" Header="Move to Bottom" Click="OnMoveStationToBottomClick"/>
                                            <Separator/>
                                            <MenuItem Header="Set Icon..." Click="OnSetStationIconClick"/>
                                            <MenuItem Header="Clear Icon" Click="OnClearStationIconClick"/>
                                            <Separator/>
                                            <MenuItem Header="Copy Name" Click="OnCopyStationNameClick"/>
                                            <MenuItem Header="Copy Stream Link" Click="OnCopyStationLinkClick"/>
                                            <MenuItem Header="Copy Station Id" Click="OnCopyStationIdClick"/>
                                            <MenuItem Header="Copy Play Command" Click="OnCopyPlayCommandClick"/>
                                            <Separator/>
                                            <MenuItem Header="Open Stream Link" Click="OnOpenStationLinkClick"/>
                                            <MenuItem x:Name="ExportM3UMenuItem" Header="Export Station as M3U Playlist..." Click="OnExportM3UClick"/>
                                        </ContextMenu>
                                    </Border.ContextMenu>
                                    <Grid ColumnDefinitions="Auto,*,Auto,Auto,Auto,Auto" ColumnSpacing="8">
                                        <Image Source="{Binding IconPath, Converter={StaticResource StationIconConverter}}" Classes="icon-small" VerticalAlignment="Top" Margin="0,1,0,0"/>
                                        <StackPanel Grid.Column="1">
                                            <StackPanel Orientation="Horizontal" Spacing="6">
                                                <TextBlock Text="{Binding Name}" FontWeight="SemiBold"/>
                                                <TextBlock Text="Now Playing" Classes="accent-text now-playing-badge" IsVisible="{Binding IsActivePlaying}"/>
                                            </StackPanel>
                                            <TextBlock Text="{Binding StreamUrl}" Classes="subtle-text"/>
                                            <TextBlock Text="{Binding Station.Id}" Classes="subtle-text" Opacity="0.6" FontSize="10"/>
                                        </StackPanel>
                                        <Button Grid.Column="2"
                                                Classes="icon-only reorder-arrow"
                                                Click="OnMoveStationUpClick">
                                            <Image Source="/Assets/arrow_up_16.ico" Classes="icon-small"/>
                                        </Button>
                                        <Button Grid.Column="3"
                                                Classes="icon-only reorder-arrow"
                                                Click="OnMoveStationDownClick">
                                            <Image Source="/Assets/arrow_down_16.ico" Classes="icon-small"/>
                                        </Button>
                                        <Button Grid.Column="4"
                                                Classes="icon-only"
                                                Click="OnPlayStationClick">
                                            <Image Source="{Binding IsActivePlaying, Converter={StaticResource PlayPauseGlyphConverter}}" Classes="icon-small"/>
                                        </Button>
                                        <Button Grid.Column="5"
                                                Classes="icon-only"
                                                Click="OnRemoveStationClick">
                                            <Image Source="/Assets/remove.ico" Classes="icon-small"/>
                                        </Button>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                    <Grid Grid.Row="1" ColumnDefinitions="*,*,Auto,Auto,Auto,Auto" ColumnSpacing="8">
                        <TextBox Grid.Column="0"
                                 Classes="input-standard"
                                 Watermark="Station name"
                                 Text="{Binding NewStationName}"
                                 IsEnabled="{Binding IsStationEditorEnabled}"/>
                        <TextBox Grid.Column="1"
                                 Classes="input-standard"
                                 Watermark="Stream URL"
                                 Text="{Binding NewStationUrl}"
                                 IsEnabled="{Binding IsStationEditorEnabled}"/>
                        <Button Grid.Column="2"
                                Classes="command-button"
                                Command="{Binding AddStationCommand}"
                                IsVisible="{Binding CanAddStation}">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <Image Source="/Assets/add.ico" Classes="icon-small"/>
                                <TextBlock Text="Add" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                        <Button Grid.Column="2"
                                Classes="command-button"
                                Command="{Binding BeginEditSelectedStationCommand}"
                                IsVisible="{Binding CanEditSelectedStation}">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <Image Source="/Assets/settings.ico" Classes="icon-small"/>
                                <TextBlock Text="Edit" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                        <Button Grid.Column="3"
                                Classes="command-button"
                                Command="{Binding SaveSelectedStationEditsCommand}"
                                IsVisible="{Binding CanSaveOrDiscardSelectedStation}">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <Image Source="/Assets/save.ico" Classes="icon-small"/>
                                <TextBlock Text="Save" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                        <Button Grid.Column="4"
                                Classes="command-button"
                                Command="{Binding DiscardSelectedStationEditsCommand}"
                                IsVisible="{Binding CanSaveOrDiscardSelectedStation}">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <Image Source="/Assets/remove.ico" Classes="icon-small"/>
                                <TextBlock Text="Discard" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                        <Button Grid.Column="5" Classes="command-button" Command="{Binding FindMoreStationsCommand}">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <Image Source="/Assets/search.ico" Classes="icon-small"/>
                                <TextBlock Text="Find More" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                    </Grid>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>

