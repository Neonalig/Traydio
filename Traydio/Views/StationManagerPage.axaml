<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Traydio.ViewModels"
             xmlns:conv="using:Traydio.Converters"
             xmlns:imaging="clr-namespace:Avalonia.Media.Imaging;assembly=Avalonia.Base"
             x:Class="Traydio.Views.StationManagerPage"
             x:Name="Root"
             x:DataType="vm:StationManagerPageViewModel"
             DragDrop.AllowDrop="True"
             DragDrop.DragOver="OnDragOver"
             DragDrop.Drop="OnDrop">
    <UserControl.Resources>
        <imaging:Bitmap x:Key="PlayIcon">avares://Traydio/Assets/Icons9x/play.ico</imaging:Bitmap>
        <imaging:Bitmap x:Key="PauseIcon">avares://Traydio/Assets/Icons9x/pause.ico</imaging:Bitmap>
        <conv:BooleanToImageConverter x:Key="PlayPauseGlyphConverter"
                                      TrueImage="{StaticResource PauseIcon}"
                                      FalseImage="{StaticResource PlayIcon}"/>
    </UserControl.Resources>


    <Grid RowDefinitions="Auto,*" RowSpacing="6" Margin="0">
        <Border Grid.Row="0" Classes="status-strip" Margin="0">
            <TextBlock Text="Tip: press Ctrl+C on a selected station to copy its ID. Right-click a station for copy/open/link command actions." Classes="helper-text"/>
        </Border>

        <Grid Grid.Row="1" RowDefinitions="Auto,*" RowSpacing="0" Margin="4,0,4,4">
            <Border Classes="group-caption-chip">
                <TextBlock Text="Saved Stations" Classes="group-title"/>
            </Border>
            <Border Grid.Row="1" Classes="group-frame" Margin="0,-8,0,0">
                <Grid RowDefinitions="*,Auto" RowSpacing="10">
                    <ListBox Grid.Row="0"
                             x:Name="StationsList"
                             Classes="list-surface"
                             ItemsSource="{Binding Stations}"
                             SelectedItem="{Binding SelectedStation}"
                             KeyDown="OnStationsListKeyDown"
                             DoubleTapped="OnStationsListDoubleTapped">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border Classes="station-entry" Classes.playing-station="{Binding IsActivePlaying}">
                                    <Border.ContextMenu>
                                        <ContextMenu>
                                            <MenuItem Header="Copy Name" Click="OnCopyStationNameClick"/>
                                            <MenuItem Header="Copy Stream Link" Click="OnCopyStationLinkClick"/>
                                            <MenuItem Header="Copy Station Id" Click="OnCopyStationIdClick"/>
                                            <MenuItem Header="Copy Play Command" Click="OnCopyPlayCommandClick"/>
                                            <MenuItem Header="Open Stream Link" Click="OnOpenStationLinkClick"/>
                                        </ContextMenu>
                                    </Border.ContextMenu>
                                    <Grid ColumnDefinitions="Auto,*,Auto,Auto" ColumnSpacing="8">
                                        <Image Source="/Assets/Icons9x/stations.ico" Classes="icon-small" VerticalAlignment="Top" Margin="0,1,0,0"/>
                                        <StackPanel Grid.Column="1">
                                            <StackPanel Orientation="Horizontal" Spacing="6">
                                                <TextBlock Text="{Binding Name}" FontWeight="SemiBold"/>
                                                <TextBlock Text="Now Playing" Classes="accent-text" IsVisible="{Binding IsActivePlaying}"/>
                                            </StackPanel>
                                            <TextBlock Text="{Binding StreamUrl}" Classes="subtle-text"/>
                                            <TextBlock Text="{Binding Station.Id}" Classes="subtle-text" Opacity="0.6" FontSize="10"/>
                                        </StackPanel>
                                        <Button Grid.Column="2"
                                                Classes="icon-only"
                                                Click="OnPlayStationClick">
                                            <Image Source="{Binding IsActivePlaying, Converter={StaticResource PlayPauseGlyphConverter}}" Classes="icon-small"/>
                                        </Button>
                                        <Button Grid.Column="3"
                                                Classes="icon-only"
                                                Click="OnRemoveStationClick">
                                            <Image Source="/Assets/Icons9x/remove.ico" Classes="icon-small"/>
                                        </Button>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                    <Grid Grid.Row="1" ColumnDefinitions="*,*,Auto,Auto" ColumnSpacing="8">
                        <TextBox Grid.Column="0" Watermark="Station name" Text="{Binding NewStationName}"/>
                        <TextBox Grid.Column="1" Watermark="Stream URL" Text="{Binding NewStationUrl}"/>
                        <Button Grid.Column="2" Classes="command-button" Command="{Binding AddStationCommand}">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <Image Source="/Assets/Icons9x/add.ico" Classes="icon-small"/>
                                <TextBlock Text="Add" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                        <Button Grid.Column="3" Classes="command-button" Command="{Binding FindMoreStationsCommand}">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <Image Source="/Assets/Icons9x/search.ico" Classes="icon-small"/>
                                <TextBlock Text="Find More" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                    </Grid>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>

