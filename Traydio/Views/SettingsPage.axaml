<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Traydio.ViewModels"
             x:Class="Traydio.Views.SettingsPage"
             x:DataType="vm:SettingsPageViewModel">

    <Border Classes="surface-card" Margin="0">
        <Grid RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto" ColumnDefinitions="Auto,*,Auto,Auto" RowSpacing="8" ColumnSpacing="8">
            <TextBlock Grid.Row="0" Grid.ColumnSpan="4" Text="Communication Settings" Classes="section-title"/>

            <CheckBox Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2" Content="Enable named pipe relay" IsChecked="{Binding EnableNamedPipeRelay}"/>
            <CheckBox Grid.Row="1" Grid.Column="2" Grid.ColumnSpan="2" Content="Enable loopback relay" IsChecked="{Binding EnableLoopbackRelay}"/>

            <TextBlock Grid.Row="2" Grid.Column="0" VerticalAlignment="Center" Text="Loopback host"/>
            <TextBox Grid.Row="2" Grid.Column="1" Text="{Binding LoopbackHost}"/>
            <TextBlock Grid.Row="2" Grid.Column="2" VerticalAlignment="Center" Text="Port"/>
            <NumericUpDown Grid.Row="2" Grid.Column="3" Minimum="1" Maximum="65535" Value="{Binding LoopbackPort}"/>

            <CheckBox Grid.Row="3" Grid.Column="0" Grid.ColumnSpan="2" Content="Enable protocol URL bridge" IsChecked="{Binding EnableProtocolUrlRelay}"/>

            <TextBlock Grid.Row="4" Grid.Column="0" VerticalAlignment="Center" Text="Protocol scheme"/>
            <TextBox Grid.Row="4" Grid.Column="1" Text="{Binding ProtocolScheme}"/>
            <TextBlock Grid.Row="4" Grid.Column="2" VerticalAlignment="Center" Text="Registered"/>
            <CheckBox Grid.Row="4" Grid.Column="3" IsEnabled="False" IsChecked="{Binding IsProtocolRegistered}"/>

            <StackPanel Grid.Row="5" Grid.Column="0" Grid.ColumnSpan="4" Orientation="Horizontal" Spacing="8">
                <Button Classes="command-button" Content="Save" Command="{Binding SaveCommand}"/>
                <Button Classes="command-button" Content="Install Protocol Handler" Command="{Binding InstallProtocolCommand}"/>
                <Button Classes="command-button" Content="Uninstall Protocol Handler" Command="{Binding UninstallProtocolCommand}"/>
                <TextBlock VerticalAlignment="Center" Text="{Binding Status}" Classes="accent-text"/>
            </StackPanel>
        </Grid>
    </Border>
</UserControl>

