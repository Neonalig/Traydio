<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Traydio.ViewModels"
             xmlns:controls="using:Traydio.Views.Controls"
             x:Class="Traydio.Views.SettingsPage"
             x:DataType="vm:SettingsPageViewModel">
    <UserControl.Styles>
        <Style Selector="TextBlock.dirty-label">
            <Setter Property="TextDecorations" Value="Underline"/>
        </Style>
    </UserControl.Styles>

    <Grid RowDefinitions="Auto,*,*,*,Auto" RowSpacing="6" Margin="0">

        <Border Grid.Row="0" Classes="status-strip" Margin="0">
            <TextBlock Text="{Binding DirtySummaryText}" Classes="helper-text"/>
        </Border>

        <Grid Grid.Row="1" RowDefinitions="Auto,*" RowSpacing="0" Margin="4,0,4,4">
            <Border Classes="group-caption-chip">
                <TextBlock Text="Communication Endpoints" Classes="group-title"/>
            </Border>
            <Border Grid.Row="1" Classes="group-frame" Margin="0,-8,0,0">
                <Grid RowDefinitions="Auto,Auto,Auto" ColumnDefinitions="Auto,*,Auto,Auto,Auto,Auto" RowSpacing="8" ColumnSpacing="8">
                    <CheckBox Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="2" IsChecked="{Binding EnableNamedPipeRelay}">
                        <controls:DirtySettingLabel LabelText="Enable named pipe relay"
                                                    LabelToolTip="Use named pipes for local machine command relay"
                                                    IsDirty="{Binding IsNamedPipeRelayDirty}"/>
                    </CheckBox>
                    <Button Grid.Row="0" Grid.Column="2"
                            Classes="icon-only"
                            ToolTip.Tip="Revert this setting to saved value"
                            IsVisible="{Binding IsNamedPipeRelayDirty}"
                            Command="{Binding ResetNamedPipeRelaySettingCommand}">
                        <Image Source="/Assets/undo.ico" Classes="icon-small"/>
                    </Button>

                    <CheckBox Grid.Row="0" Grid.Column="3" Grid.ColumnSpan="2" IsChecked="{Binding EnableLoopbackRelay}">
                        <controls:DirtySettingLabel LabelText="Enable loopback relay"
                                                    LabelToolTip="Use loopback TCP command relay"
                                                    IsDirty="{Binding IsLoopbackRelayDirty}"/>
                    </CheckBox>
                    <Button Grid.Row="0" Grid.Column="5"
                            Classes="icon-only"
                            ToolTip.Tip="Revert this setting to saved value"
                            IsVisible="{Binding IsLoopbackRelayDirty}"
                            Command="{Binding ResetLoopbackRelaySettingCommand}">
                        <Image Source="/Assets/undo.ico" Classes="icon-small"/>
                    </Button>

                    <controls:DirtySettingLabel Grid.Row="1"
                                                Grid.Column="0"
                                                LabelText="Loopback host"
                                                LabelToolTip="Loopback host used for TCP relay"
                                                IsDirty="{Binding IsLoopbackHostDirty}"/>
                    <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding LoopbackHost}"/>
                    <Button Grid.Row="1" Grid.Column="2"
                            Classes="icon-only"
                            ToolTip.Tip="Revert this setting to saved value"
                            IsVisible="{Binding IsLoopbackHostDirty}"
                            Command="{Binding ResetLoopbackHostSettingCommand}">
                        <Image Source="/Assets/undo.ico" Classes="icon-small"/>
                    </Button>

                    <controls:DirtySettingLabel Grid.Row="1"
                                                Grid.Column="3"
                                                LabelText="Port"
                                                LabelToolTip="Loopback TCP port used for relay"
                                                IsDirty="{Binding IsLoopbackPortDirty}"/>
                    <NumericUpDown Grid.Row="1" Grid.Column="4" Minimum="1" Maximum="65535" Value="{Binding LoopbackPort}"/>
                    <Button Grid.Row="1" Grid.Column="5"
                            Classes="icon-only"
                            ToolTip.Tip="Revert this setting to saved value"
                            IsVisible="{Binding IsLoopbackPortDirty}"
                            Command="{Binding ResetLoopbackPortSettingCommand}">
                        <Image Source="/Assets/undo.ico" Classes="icon-small"/>
                    </Button>

                    <TextBlock Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="6" Text="Use named pipes for local machine reliability; use loopback when you need protocol compatibility over TCP." Classes="helper-text"/>
                </Grid>
            </Border>
        </Grid>

        <Grid Grid.Row="2" RowDefinitions="Auto,*" RowSpacing="0" Margin="4,0,4,4">
            <Border Classes="group-caption-chip">
                <TextBlock Text="Playback" Classes="group-title"/>
            </Border>
            <Border Grid.Row="1" Classes="group-frame" Margin="0,-8,0,0">
                <Grid RowDefinitions="Auto,Auto,Auto,Auto" ColumnDefinitions="Auto,*,Auto,Auto" RowSpacing="8" ColumnSpacing="8">
                    <controls:DirtySettingLabel Grid.Row="0"
                                                Grid.Column="0"
                                                LabelText="Playback engine"
                                                LabelToolTip="Select the radio playback backend"
                                                IsDirty="{Binding IsRadioPlayerEngineDirty}"/>
                    <ComboBox Grid.Row="0" Grid.Column="1"
                              ItemsSource="{Binding RadioPlayerEngines}"
                              SelectedItem="{Binding SelectedRadioPlayerEngine}">
                        <ComboBox.ItemTemplate>
                            <DataTemplate x:DataType="vm:RadioPlayerEngineOption">
                                <TextBlock Text="{Binding Name}"/>
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>
                    <Button Grid.Row="0" Grid.Column="2"
                            Classes="icon-only"
                            ToolTip.Tip="Revert this setting to saved value"
                            IsVisible="{Binding IsRadioPlayerEngineDirty}"
                            Command="{Binding ResetPlaybackEngineSettingCommand}">
                        <Image Source="/Assets/undo.ico" Classes="icon-small"/>
                    </Button>

                    <controls:DirtySettingLabel Grid.Row="1"
                                                Grid.Column="0"
                                                LabelText="Audio output device"
                                                LabelToolTip="Select preferred audio output device"
                                                IsDirty="{Binding IsAudioOutputDeviceDirty}"/>
                    <ComboBox Grid.Row="1" Grid.Column="1"
                              ItemsSource="{Binding AudioOutputDevices}"
                              SelectedItem="{Binding SelectedAudioOutputDevice}">
                        <ComboBox.ItemTemplate>
                            <DataTemplate x:DataType="vm:AudioOutputDeviceOption">
                                <TextBlock Text="{Binding Name}"/>
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>
                    <Button Grid.Row="1" Grid.Column="2"
                            Classes="icon-only"
                            ToolTip.Tip="Revert this setting to saved value"
                            IsVisible="{Binding IsAudioOutputDeviceDirty}"
                            Command="{Binding ResetAudioOutputDeviceSettingCommand}">
                        <Image Source="/Assets/undo.ico" Classes="icon-small"/>
                    </Button>

                    <controls:DirtySettingLabel Grid.Row="2"
                                                Grid.Column="0"
                                                LabelText="Classic theme"
                                                LabelToolTip="Select the classic UI color theme"
                                                IsDirty="{Binding IsClassicThemeDirty}"/>
                    <ComboBox Grid.Row="2" Grid.Column="1"
                              ItemsSource="{Binding ClassicThemes}"
                              SelectedItem="{Binding SelectedClassicTheme}">
                        <ComboBox.ItemTemplate>
                            <DataTemplate x:DataType="vm:ClassicThemeOption">
                                <TextBlock Text="{Binding Name}"/>
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>
                    <Button Grid.Row="2" Grid.Column="2"
                            Classes="icon-only"
                            ToolTip.Tip="Revert this setting to saved value"
                            IsVisible="{Binding IsClassicThemeDirty}"
                            Command="{Binding ResetClassicThemeSettingCommand}">
                        <Image Source="/Assets/undo.ico" Classes="icon-small"/>
                    </Button>

                    <Button Grid.Row="2"
                            Grid.Column="3"
                            Classes="command-button"
                            IsVisible="{Binding IsThemeRestartVisible}"
                            Click="OnApplyThemeClick">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <Image Source="/Assets/save.ico" Classes="icon-small"/>
                            <TextBlock Text="Save &amp; Apply" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <TextBlock Grid.Row="3" Grid.Column="0" Grid.ColumnSpan="4"
                               Text="Engine changes apply after restart. Use System default unless you want to force a specific playback endpoint."
                               Classes="helper-text"/>
                </Grid>
            </Border>
        </Grid>

        <Grid Grid.Row="3" RowDefinitions="Auto,*" RowSpacing="0" Margin="4,0,4,4">
            <Border Classes="group-caption-chip">
                <TextBlock Text="Protocol Bridge" Classes="group-title"/>
            </Border>
            <Border Grid.Row="1" Classes="group-frame" Margin="0,-8,0,0">
                <Grid RowDefinitions="Auto,Auto,Auto,Auto,Auto" ColumnDefinitions="Auto,*,Auto,Auto" RowSpacing="8" ColumnSpacing="8">
                    <CheckBox Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="2" IsChecked="{Binding EnableProtocolUrlRelay}">
                        <controls:DirtySettingLabel LabelText="Enable protocol URL bridge"
                                                    LabelToolTip="Enable traydio:// command protocol bridge"
                                                    IsDirty="{Binding IsProtocolUrlRelayDirty}"/>
                    </CheckBox>
                    <Button Grid.Row="0" Grid.Column="2"
                            Classes="icon-only"
                            ToolTip.Tip="Revert this setting to saved value"
                            IsVisible="{Binding IsProtocolUrlRelayDirty}"
                            Command="{Binding ResetProtocolUrlRelaySettingCommand}">
                        <Image Source="/Assets/undo.ico" Classes="icon-small"/>
                    </Button>
                    <Button Grid.Row="0"
                            Grid.Column="3"
                            Classes="command-button"
                            HorizontalAlignment="Right"
                            HorizontalContentAlignment="Center"
                            VerticalContentAlignment="Center"
                            Command="{Binding ToggleProtocolRegistrationCommand}">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <Image Source="/Assets/add.ico" Classes="icon-small" IsVisible="{Binding !IsProtocolRegistered}"/>
                            <Image Source="/Assets/remove.ico" Classes="icon-small" IsVisible="{Binding IsProtocolRegistered}"/>
                            <TextBlock Text="{Binding ProtocolActionText}" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <controls:DirtySettingLabel Grid.Row="1"
                                                Grid.Column="0"
                                                LabelText="Protocol scheme"
                                                LabelToolTip="Scheme name used for protocol registration"
                                                IsDirty="{Binding IsProtocolSchemeDirty}"/>
                    <TextBox Grid.Row="1" Grid.Column="1" Classes="input-standard" Text="{Binding ProtocolScheme}"/>
                    <Button Grid.Row="1" Grid.Column="2"
                            Classes="icon-only"
                            ToolTip.Tip="Revert this setting to saved value"
                            IsVisible="{Binding IsProtocolSchemeDirty}"
                            Command="{Binding ResetProtocolSchemeSettingCommand}">
                        <Image Source="/Assets/undo.ico" Classes="icon-small"/>
                    </Button>

                    <TextBlock Grid.Row="2" Grid.Column="0" VerticalAlignment="Center" Text="Extended functionality"/>
                    <Button Grid.Row="2"
                            Grid.Column="1"
                            Classes="command-button"
                            HorizontalAlignment="Left"
                            Command="{Binding InstallWmicExtendedFunctionalityCommand}"
                            IsEnabled="{Binding IsWmicSupported}"
                            IsVisible="{Binding !IsWmicInstalled}">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <Image Source="/Assets/add.ico" Classes="icon-small"/>
                            <TextBlock Text="Install WMIC Utility" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <TextBlock Grid.Row="2" Grid.Column="2" VerticalAlignment="Center" Text="Installed"/>
                    <CheckBox Grid.Row="2" Grid.Column="3" IsEnabled="False" IsChecked="{Binding IsWmicInstalled}"/>

                    <StackPanel Grid.Row="3" Grid.Column="0" Grid.ColumnSpan="4" Orientation="Horizontal" Spacing="4">
                        <TextBlock Text="WMIC:" FontWeight="SemiBold"/>
                        <TextBlock Text="{Binding WmicStatus}" Classes="helper-text"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>

        <Border Grid.Row="4" Classes="toolbar-frame" Margin="0">
            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                <TextBlock Grid.Column="0"
                           Text="{Binding Status}"
                           Classes="accent-text"
                           VerticalAlignment="Center"/>
                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="6" HorizontalAlignment="Right">
                    <Button Classes="toolbar-button"
                            HorizontalContentAlignment="Center"
                            VerticalContentAlignment="Center"
                            Command="{Binding SaveCommand}"
                            IsEnabled="{Binding HasUnsavedChanges}">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <Image Source="/Assets/save.ico" Classes="icon-small"/>
                            <TextBlock Text="Save Settings" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <Button Classes="toolbar-button"
                            HorizontalContentAlignment="Center"
                            VerticalContentAlignment="Center"
                            Command="{Binding DiscardChangesCommand}"
                            IsEnabled="{Binding HasUnsavedChanges}">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <Image Source="/Assets/remove.ico" Classes="icon-small"/>
                            <TextBlock Text="Discard" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <Button Classes="toolbar-button"
                            HorizontalContentAlignment="Center"
                            VerticalContentAlignment="Center"
                            Command="{Binding ResetAllDefaultsCommand}">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <Image Source="/Assets/reset_to_default.ico" Classes="icon-small"/>
                            <TextBlock Text="Reset to Defaults" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</UserControl>

