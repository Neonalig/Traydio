<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:views="using:Traydio.Views"
             xmlns:vm="using:Traydio.ViewModels"
             x:Class="Traydio.Views.CommandTesterPage"
             x:DataType="vm:CommandTesterPageViewModel">
    <Grid Margin="0" RowDefinitions="Auto,Auto,*" RowSpacing="6">
        <Border Grid.Row="0" Classes="toolbar-frame" Margin="0">
            <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="8">
                <TextBox Classes="input-standard"
                         Grid.Column="0"
                         Watermark="Try: play, volume 35, plugins"
                         Text="{Binding CommandText, Mode=TwoWay}"/>
                <Button Grid.Column="1" Classes="command-button" Command="{Binding RunCommand}">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <Image Source="/Assets/play.ico" Classes="icon-small"/>
                        <TextBlock Text="Run" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
                <Button Grid.Column="2" Classes="command-button" Command="{Binding ClearCommand}">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <Image Source="/Assets/remove.ico" Classes="icon-small"/>
                        <TextBlock Text="Clear" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
            </Grid>
        </Border>

        <Border Grid.Row="1" Classes="status-strip" Margin="0">
            <TextBlock Classes="helper-text" Text="{Binding Status}"/>
        </Border>

        <Grid Grid.Row="2" RowDefinitions="Auto,*" RowSpacing="0" Margin="4,0,4,4">
            <Border Classes="group-caption-chip">
                <TextBlock Text="Command Syntax Hints" Classes="group-title"/>
            </Border>
            <Border Grid.Row="1" Classes="group-frame" Margin="0,-8,0,0">
                <Grid RowDefinitions="Auto,*" RowSpacing="8">
                    <TextBlock Grid.Row="0"
                               Text="Commands are routed through ICommandTextRouter. Use station IDs from Station Manager for the station command."
                               Classes="helper-text"/>
                    <ItemsControl Grid.Row="1" ItemsSource="{Binding SyntaxHints}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="views:CommandTipItem">
                                <StackPanel Orientation="Horizontal" Spacing="6" Margin="0,0,0,4" ToolTip.Tip="{ReflectionBinding Tooltip}">
                                    <Image Source="/Assets/info.ico"
                                           Classes="icon-small"/>
                                    <Border Classes="tip-help-box">
                                        <TextBlock Text="{ReflectionBinding Command}"/>
                                    </Border>
                                </StackPanel>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>

