<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:Traydio.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        x:Class="Traydio.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Icon="/Assets/internet-radio.ico"
        Width="1100"
        Height="760"
        Title="Traydio">

    <Grid RowDefinitions="Auto,*,Auto" Margin="12" RowSpacing="12">
        <WrapPanel Grid.Row="0" Orientation="Horizontal" ItemWidth="240" ItemHeight="120" HorizontalAlignment="Center">
            <Button Command="{Binding OpenStationsCommand}" Margin="6">
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="6">
                    <TextBlock Text="[STATIONS]" FontSize="16" HorizontalAlignment="Center"/>
                    <TextBlock Text="Stations Manager" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                </StackPanel>
            </Button>

            <Button Command="{Binding OpenSearchCommand}" Margin="6">
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="6">
                    <TextBlock Text="[SEARCH]" FontSize="16" HorizontalAlignment="Center"/>
                    <TextBlock Text="Add Stations Search" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                </StackPanel>
            </Button>

            <Button Command="{Binding OpenPluginsCommand}" Margin="6">
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="6">
                    <TextBlock Text="[PLUGINS]" FontSize="16" HorizontalAlignment="Center"/>
                    <TextBlock Text="Plugins" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                </StackPanel>
            </Button>

            <Button Command="{Binding OpenSettingsCommand}" Margin="6">
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="6">
                    <TextBlock Text="[SETTINGS]" FontSize="16" HorizontalAlignment="Center"/>
                    <TextBlock Text="Settings" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                </StackPanel>
            </Button>
        </WrapPanel>

        <Border Grid.Row="1" BorderBrush="#445" BorderThickness="1" CornerRadius="8" Padding="8">
            <ContentControl Content="{Binding CurrentPageViewModel}"/>
        </Border>

        <Border Grid.Row="2"
                BorderBrush="#445"
                BorderThickness="1"
                CornerRadius="8"
                Padding="8"
                IsVisible="{Binding IsMediaBarVisible}">
            <Grid RowDefinitions="Auto,Auto" RowSpacing="6" Opacity="{Binding MediaControlsOpacity}">
                <Grid Grid.Row="0" ColumnDefinitions="Auto,Auto,Auto,*,Auto" ColumnSpacing="10">
                    <Button Grid.Column="0" Content="{Binding PlayPauseIcon}" Command="{Binding TogglePlayPauseCommand}" MinWidth="92"/>
                    <Button Grid.Column="1" Content="Mute" Command="{Binding ToggleMuteCommand}" MinWidth="80"/>
                    <TextBlock Grid.Column="2" VerticalAlignment="Center" Text="{Binding PlaybackTimeText}"/>
                    <TextBlock Grid.Column="3" VerticalAlignment="Center" Text="{Binding CurrentStationText}" FontWeight="SemiBold"/>
                    <ProgressBar Grid.Column="4" Width="120" IsIndeterminate="True" IsVisible="{Binding IsMediaLoading}"/>
                </Grid>

                <Grid Grid.Row="1" ColumnDefinitions="Auto,*,*" ColumnSpacing="8">
                    <TextBlock Grid.Column="0" VerticalAlignment="Center" Text="Volume"/>
                    <Slider Grid.Column="1" Minimum="0" Maximum="100" Value="{Binding FooterVolume}"/>
                    <StackPanel Grid.Column="2" Spacing="2">
                        <TextBlock Text="{Binding NowPlayingText}" Opacity="0.85" TextWrapping="Wrap"/>
                        <TextBlock Text="{Binding MediaErrorText}" Foreground="#E57373" TextWrapping="Wrap"/>
                    </StackPanel>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</Window>
