<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:Traydio.ViewModels"
        xmlns:conv="using:Traydio.Converters"
        xmlns:imaging="clr-namespace:Avalonia.Media.Imaging;assembly=Avalonia.Base"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        x:Class="Traydio.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Icon="/Assets/Icons9x/stations.ico"
        Width="1100"
        Height="760"
        Title="Traydio">
    <Window.Resources>
        <imaging:Bitmap x:Key="PlayIcon">avares://Traydio/Assets/Icons9x/play.ico</imaging:Bitmap>
        <imaging:Bitmap x:Key="PauseIcon">avares://Traydio/Assets/Icons9x/pause.ico</imaging:Bitmap>
        <imaging:Bitmap x:Key="VolumeIcon">avares://Traydio/Assets/Icons9x/volume.ico</imaging:Bitmap>
        <imaging:Bitmap x:Key="MuteIcon">avares://Traydio/Assets/Icons9x/mute.ico</imaging:Bitmap>

        <conv:BooleanToImageConverter x:Key="PlayPauseIconConverter"
                                      TrueImage="{StaticResource PauseIcon}"
                                      FalseImage="{StaticResource PlayIcon}"/>
        <conv:BooleanToImageConverter x:Key="VolumeMuteIconConverter"
                                      TrueImage="{StaticResource MuteIcon}"
                                      FalseImage="{StaticResource VolumeIcon}"/>
    </Window.Resources>

    <Grid RowDefinitions="Auto,Auto,*,Auto" RowSpacing="6">
        <Border Grid.Row="0" Classes="toolbar-frame" Margin="0">
            <Grid RowDefinitions="Auto,Auto" RowSpacing="6">
                <Grid Grid.Row="0" ColumnDefinitions="*,Auto" ColumnSpacing="8">
                    <TextBlock Text="Traydio - Internet Radio Control Center" Classes="section-title"/>
                    <TextBlock Grid.Column="1" Text="Ready" VerticalAlignment="Center" Classes="accent-text"/>
                </Grid>

                <StackPanel Grid.Row="1" Orientation="Horizontal" Spacing="6">
                    <Button Classes="toolbar-button" Command="{Binding OpenStationsCommand}">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <Image Source="/Assets/Icons9x/stations.ico" Classes="icon-small"/>
                            <TextBlock Text="Station Manager" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <Button Classes="toolbar-button" Command="{Binding OpenSearchCommand}">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <Image Source="/Assets/Icons9x/search.ico" Classes="icon-small"/>
                            <TextBlock Text="Search Catalog" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <Button Classes="toolbar-button" Command="{Binding OpenPluginsCommand}">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <Image Source="/Assets/Icons9x/plugins.ico" Classes="icon-small"/>
                            <TextBlock Text="Plugin Manager" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <Button Classes="toolbar-button" Command="{Binding OpenSettingsCommand}">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <Image Source="/Assets/Icons9x/settings.ico" Classes="icon-small"/>
                            <TextBlock Text="Settings" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <Border Grid.Row="1" Classes="status-strip" Margin="0">
            <TextBlock Text="Choose a command from the toolbar. Each page explains what to do next and which action commits your changes." Classes="helper-text"/>
        </Border>

        <Grid Grid.Row="2" RowDefinitions="Auto,*" RowSpacing="0" Margin="4,0,4,4">
            <Border Classes="group-caption-chip">
                <TextBlock Text="Workspace" Classes="group-title"/>
            </Border>
            <Border Grid.Row="1" Classes="group-frame" Margin="0,-8,0,0">
                <ContentControl Content="{Binding CurrentPageViewModel}"/>
            </Border>
        </Grid>

        <Grid Grid.Row="3" RowDefinitions="Auto,*" RowSpacing="0" Margin="4,0,4,4" IsVisible="{Binding IsMediaBarVisible}">
            <Border Classes="group-caption-chip">
                <TextBlock Text="Playback Console" Classes="group-title"/>
            </Border>
            <Border Grid.Row="1" Classes="group-frame" Margin="0,-8,0,0">
                <Grid ColumnDefinitions="Auto,Auto,*,Auto,*,Auto" ColumnSpacing="8" Opacity="{Binding MediaControlsOpacity}">
                    <Button Grid.Column="0" Classes="icon-only" Command="{Binding TogglePlayPauseCommand}">
                        <Image Source="{Binding IsMediaPlaying, Converter={StaticResource PlayPauseIconConverter}}" Classes="icon-small"/>
                    </Button>

                    <TextBlock Grid.Column="1" VerticalAlignment="Center" Text="{Binding PlaybackTimeText}" Classes="subtle-text"/>

                    <Grid Grid.Column="2">
                        <TextBlock VerticalAlignment="Center"
                                   Text="{Binding MediaCenterText}"
                                   FontWeight="SemiBold"
                                   TextWrapping="Wrap"
                                   IsVisible="{Binding !HasMediaError}"/>
                        <TextBlock VerticalAlignment="Center"
                                   Text="{Binding MediaCenterText}"
                                   TextWrapping="Wrap"
                                   Classes="error-text"
                                   IsVisible="{Binding HasMediaError}"/>
                    </Grid>

                    <ProgressBar Grid.Column="3" Width="110" IsIndeterminate="True" IsVisible="{Binding IsMediaLoading}"/>

                    <Grid Grid.Column="4" ColumnDefinitions="Auto,*,Auto" ColumnSpacing="6" VerticalAlignment="Center">
                        <Button Grid.Column="0" Classes="icon-only" Command="{Binding ToggleMuteCommand}">
                            <Image Source="{Binding IsMediaMuted, Converter={StaticResource VolumeMuteIconConverter}}" Classes="icon-small"/>
                        </Button>
                        <Slider Grid.Column="1" Minimum="0" Maximum="100" Width="120" Value="{Binding FooterVolume}"/>
                        <TextBlock Grid.Column="2" VerticalAlignment="Center" Text="{Binding FooterVolumeText}" Classes="subtle-text"/>
                    </Grid>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>
