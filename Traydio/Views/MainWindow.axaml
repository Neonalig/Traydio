<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:Traydio.ViewModels"
        xmlns:conv="using:Traydio.Converters"
        xmlns:imaging="clr-namespace:Avalonia.Media.Imaging;assembly=Avalonia.Base"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        x:Class="Traydio.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Icon="/Assets/Icons9x/stations.ico"
        Width="1100"
        Height="760"
        Title="Traydio - Internet Radio Control Center">
    <Window.Resources>
        <imaging:Bitmap x:Key="PlayIcon">avares://Traydio/Assets/Icons9x/play.ico</imaging:Bitmap>
        <imaging:Bitmap x:Key="PauseIcon">avares://Traydio/Assets/Icons9x/pause.ico</imaging:Bitmap>
        <imaging:Bitmap x:Key="VolumeIcon">avares://Traydio/Assets/Icons9x/volume.ico</imaging:Bitmap>
        <imaging:Bitmap x:Key="MuteIcon">avares://Traydio/Assets/Icons9x/mute.ico</imaging:Bitmap>

        <conv:BooleanToImageConverter x:Key="PlayPauseIconConverter"
                                      TrueImage="{StaticResource PauseIcon}"
                                      FalseImage="{StaticResource PlayIcon}"/>
        <conv:BooleanToImageConverter x:Key="VolumeMuteIconConverter"
                                      TrueImage="{StaticResource MuteIcon}"
                                      FalseImage="{StaticResource VolumeIcon}"/>
    </Window.Resources>

    <Grid RowDefinitions="Auto,Auto,*,Auto" RowSpacing="6">
        <Border Grid.Row="0" Classes="toolbar-frame" Margin="0">
            <Grid RowDefinitions="Auto,Auto" RowSpacing="6">
                <TextBlock HorizontalAlignment="Right" Text="Ready" VerticalAlignment="Center" Classes="accent-text"/>

                <StackPanel Grid.Row="1" Orientation="Horizontal" Spacing="6">
                    <Button Classes="ribbon-button" Command="{Binding OpenStationsCommand}">
                        <StackPanel Orientation="Vertical" Spacing="4" HorizontalAlignment="Center">
                            <Image Source="/Assets/Icons9x/stations.ico" Classes="icon-ribbon" HorizontalAlignment="Center"/>
                            <TextBlock Text="Stations" TextAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <Button Classes="ribbon-button" Command="{Binding OpenSearchCommand}">
                        <StackPanel Orientation="Vertical" Spacing="4" HorizontalAlignment="Center">
                            <Image Source="/Assets/Icons9x/search.ico" Classes="icon-ribbon" HorizontalAlignment="Center"/>
                            <TextBlock Text="Search" TextAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <Button Classes="ribbon-button" Command="{Binding OpenPluginsCommand}">
                        <StackPanel Orientation="Vertical" Spacing="4" HorizontalAlignment="Center">
                            <Image Source="/Assets/Icons9x/plugins.ico" Classes="icon-ribbon" HorizontalAlignment="Center"/>
                            <TextBlock Text="Plugins" TextAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <Button Classes="ribbon-button" Command="{Binding OpenSettingsCommand}">
                        <StackPanel Orientation="Vertical" Spacing="4" HorizontalAlignment="Center">
                            <Image Source="/Assets/Icons9x/settings.ico" Classes="icon-ribbon" HorizontalAlignment="Center"/>
                            <TextBlock Text="Settings" TextAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <Button Classes="ribbon-button" Command="{Binding OpenCommandsCommand}">
                        <StackPanel Orientation="Vertical" Spacing="4" HorizontalAlignment="Center">
                            <Image Source="/Assets/Icons9x/info.ico" Classes="icon-ribbon" HorizontalAlignment="Center"/>
                            <TextBlock Text="Commands" TextAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <Border Grid.Row="1" Classes="status-strip" Margin="0">
            <TextBlock Text="Use the ribbon to switch pages. The Commands page includes syntax hints and a test runner for command text routing." Classes="helper-text"/>
        </Border>

        <Grid Grid.Row="2" RowDefinitions="Auto,*" RowSpacing="0" Margin="4,0,4,4">
            <Border Classes="group-caption-chip">
                <TextBlock Text="Workspace" Classes="group-title"/>
            </Border>
            <Border Grid.Row="1" Classes="group-frame" Margin="0,-8,0,0">
                <ContentControl Content="{Binding CurrentPageViewModel}"/>
            </Border>
        </Grid>

        <Grid Grid.Row="3" RowDefinitions="Auto,*" RowSpacing="0" Margin="4,0,4,4" IsVisible="{Binding IsMediaBarVisible}">
            <Border Classes="group-caption-chip">
                <TextBlock Text="Playback Console" Classes="group-title"/>
            </Border>
            <Border Grid.Row="1" Classes="group-frame" Margin="0,-8,0,0">
                <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="12" Opacity="{Binding MediaControlsOpacity}">
                    <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                        <Button Classes="icon-only" Command="{Binding TogglePlayPauseCommand}">
                            <Image Source="{Binding IsMediaPlaying, Converter={StaticResource PlayPauseIconConverter}}" Classes="icon-small"/>
                        </Button>
                        <TextBlock VerticalAlignment="Center" Text="{Binding PlaybackTimeText}" Classes="subtle-text"/>
                    </StackPanel>

                    <Grid Grid.Column="1">
                        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" MaxWidth="560">
                            <TextBlock Text="{Binding MediaCenterText}"
                                       FontWeight="SemiBold"
                                       TextWrapping="Wrap"
                                       TextAlignment="Center"
                                       IsVisible="{Binding !HasMediaError}"/>
                            <TextBlock Text="{Binding MediaCenterText}"
                                       TextWrapping="Wrap"
                                       TextAlignment="Center"
                                       Classes="error-text"
                                       IsVisible="{Binding HasMediaError}"/>
                        </StackPanel>
                        <ProgressBar HorizontalAlignment="Right" VerticalAlignment="Center" Width="110" IsIndeterminate="True" IsVisible="{Binding IsMediaLoading}"/>
                    </Grid>

                    <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                        <Button Classes="icon-only" Command="{Binding ToggleMuteCommand}">
                            <Image Source="{Binding IsMediaMuted, Converter={StaticResource VolumeMuteIconConverter}}" Classes="icon-small"/>
                        </Button>
                        <Slider Minimum="0" Maximum="100" Width="120" Value="{Binding FooterVolume}" IsEnabled="{Binding !IsMediaMuted}"/>
                        <TextBlock VerticalAlignment="Center" Text="{Binding FooterVolumeText}" Classes="subtle-text" IsEnabled="{Binding !IsMediaMuted}"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>
