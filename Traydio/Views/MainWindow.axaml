<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:Traydio.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        x:Class="Traydio.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Icon="/Assets/internet-radio.ico"
        Width="1100"
        Height="760"
        Title="Traydio">
    <Grid RowDefinitions="Auto,Auto,*,Auto" RowSpacing="6">
        <Border Grid.Row="0" Classes="toolbar-frame" Margin="0">
            <Grid RowDefinitions="Auto,Auto" RowSpacing="6">
                <Grid Grid.Row="0" ColumnDefinitions="*,Auto" ColumnSpacing="8">
                    <TextBlock Text="Traydio - Internet Radio Control Center" Classes="section-title"/>
                    <TextBlock Grid.Column="1" Text="Ready" VerticalAlignment="Center" Classes="accent-text"/>
                </Grid>

                <StackPanel Grid.Row="1" Orientation="Horizontal" Spacing="6">
                    <Button Classes="toolbar-button" Command="{Binding OpenStationsCommand}">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <Image Source="/Assets/Icons9x/stations.ico" Classes="icon-small"/>
                            <TextBlock Text="Station Manager" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <Button Classes="toolbar-button" Command="{Binding OpenSearchCommand}">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <Image Source="/Assets/Icons9x/search.ico" Classes="icon-small"/>
                            <TextBlock Text="Search Catalog" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <Button Classes="toolbar-button" Command="{Binding OpenPluginsCommand}">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <Image Source="/Assets/Icons9x/plugins.ico" Classes="icon-small"/>
                            <TextBlock Text="Plugin Manager" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <Button Classes="toolbar-button" Command="{Binding OpenSettingsCommand}">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <Image Source="/Assets/Icons9x/settings.ico" Classes="icon-small"/>
                            <TextBlock Text="Settings" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <Border Grid.Row="1" Classes="status-strip" Margin="0">
            <TextBlock Text="Choose a command from the toolbar. Each page explains what to do next and which action commits your changes." Classes="helper-text"/>
        </Border>

        <Grid Grid.Row="2" RowDefinitions="Auto,*" RowSpacing="0" Margin="4,0,4,4">
            <Border Classes="group-caption-chip">
                <TextBlock Text="Workspace" Classes="group-title"/>
            </Border>
            <Border Grid.Row="1" Classes="group-frame" Margin="0,-8,0,0">
                <ContentControl Content="{Binding CurrentPageViewModel}"/>
            </Border>
        </Grid>

        <Grid Grid.Row="3" RowDefinitions="Auto,*" RowSpacing="0" Margin="4,0,4,4" IsVisible="{Binding IsMediaBarVisible}">
            <Border Classes="group-caption-chip">
                <TextBlock Text="Playback Console" Classes="group-title"/>
            </Border>
            <Border Grid.Row="1" Classes="group-frame" Margin="0,-8,0,0">
                <Grid RowDefinitions="Auto,Auto" RowSpacing="8" Opacity="{Binding MediaControlsOpacity}">
                    <Grid Grid.Row="0" ColumnDefinitions="Auto,Auto,Auto,*,Auto" ColumnSpacing="8">
                        <Button Grid.Column="0" Classes="command-button" Command="{Binding TogglePlayPauseCommand}">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <Image Source="/Assets/Icons9x/play.ico" Classes="icon-small"/>
                                <TextBlock Text="{Binding PlayPauseIcon}" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                        <Button Grid.Column="1" Classes="command-button" Command="{Binding ToggleMuteCommand}">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <Image Source="/Assets/Icons9x/mute.ico" Classes="icon-small"/>
                                <TextBlock Text="Mute" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                        <TextBlock Grid.Column="2" VerticalAlignment="Center" Text="{Binding PlaybackTimeText}" Classes="subtle-text"/>
                        <TextBlock Grid.Column="3" VerticalAlignment="Center" Text="{Binding CurrentStationText}" FontWeight="SemiBold"/>
                        <ProgressBar Grid.Column="4" Width="130" IsIndeterminate="True" IsVisible="{Binding IsMediaLoading}"/>
                    </Grid>

                    <Grid Grid.Row="1" ColumnDefinitions="Auto,*,*" ColumnSpacing="8">
                        <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="4" VerticalAlignment="Center">
                            <Image Source="/Assets/Icons9x/volume.ico" Classes="icon-small"/>
                            <TextBlock Text="Volume"/>
                        </StackPanel>
                        <Slider Grid.Column="1" Minimum="0" Maximum="100" Value="{Binding FooterVolume}"/>
                        <StackPanel Grid.Column="2" Spacing="2">
                            <TextBlock Text="{Binding NowPlayingText}" Classes="helper-text"/>
                            <TextBlock Text="{Binding MediaErrorText}" Classes="error-text" TextWrapping="Wrap"/>
                        </StackPanel>
                    </Grid>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>
