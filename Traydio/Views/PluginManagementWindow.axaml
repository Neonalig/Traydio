<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Traydio.ViewModels"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             x:Class="Traydio.Views.PluginManagementPage"
             x:DataType="vm:PluginManagementWindowViewModel">

    <Grid Margin="0" RowDefinitions="Auto,Auto,*,*,Auto" RowSpacing="8">
        <TextBlock Grid.Row="0" Text="Plugin Management" Classes="section-title"/>

        <Border Grid.Row="1" Classes="surface-card" Margin="0">
            <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="8">
                <TextBlock Grid.Column="0" VerticalAlignment="Center" Text="Plugin directory"/>
                <TextBox Grid.Column="1" Text="{Binding PluginDirectory}"/>
                <Button Grid.Column="2" Classes="command-button" Content="Save Directory" Command="{Binding SavePluginDirectoryCommand}"/>
            </Grid>
        </Border>

        <Border Grid.Row="2" Classes="surface-card" Margin="0">
            <Grid RowDefinitions="Auto,*,Auto" RowSpacing="8">
                <TextBlock Grid.Row="0" Text="Installed Plugins" FontWeight="SemiBold"/>
                <ListBox Grid.Row="1" Classes="list-surface" ItemsSource="{Binding InstalledPlugins}" SelectedItem="{Binding SelectedInstalledPlugin}" DisplayMemberBinding="{Binding DisplayName}"/>
                <Button Grid.Row="2" Classes="command-button" Content="Disable Selected" Command="{Binding DisableSelectedPluginCommand}" HorizontalAlignment="Left"/>
            </Grid>
        </Border>

        <Border Grid.Row="3" Classes="surface-card" Margin="0">
            <Grid RowDefinitions="Auto,*,Auto,Auto" RowSpacing="8">
                <TextBlock Grid.Row="0" Text="Discovered Eligible Plugin DLLs" FontWeight="SemiBold"/>
                <ListBox Grid.Row="1" Classes="list-surface" ItemsSource="{Binding PluginCandidates}" SelectedItem="{Binding SelectedPluginCandidate}">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel>
                                <TextBlock Text="{Binding DisplayName}" FontWeight="SemiBold"/>
                                <TextBlock Text="{Binding Path}" Classes="subtle-text" TextWrapping="Wrap"/>
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

                <StackPanel Grid.Row="2" Orientation="Horizontal" Spacing="8">
                    <Button Classes="command-button" Content="Install Selected Candidate" Command="{Binding InstallSelectedCandidateCommand}"/>
                    <Button Classes="command-button" Content="Refresh" Command="{Binding RefreshCommand}"/>
                </StackPanel>

                <Grid Grid.Row="3" ColumnDefinitions="*,Auto,Auto" ColumnSpacing="8">
                    <TextBox Grid.Column="0" Watermark="Browse or paste plugin DLL path" Text="{Binding PluginDllPath}"/>
                    <Button Grid.Column="1" Classes="command-button" Content="Browse..." Click="OnBrowsePluginClick"/>
                    <Button Grid.Column="2" Classes="command-button" Content="Install From Path" Command="{Binding InstallFromPathCommand}"/>
                </Grid>
            </Grid>
        </Border>

        <TextBlock Grid.Row="4" Text="{Binding Status}" Classes="accent-text"/>
    </Grid>
</UserControl>

