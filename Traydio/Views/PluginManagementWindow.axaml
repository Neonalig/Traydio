<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Traydio.ViewModels"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             x:Class="Traydio.Views.PluginManagementPage"
             x:DataType="vm:PluginManagementWindowViewModel">
    <Grid Margin="0" RowDefinitions="Auto,Auto,*,Auto" RowSpacing="6">
        <Border Grid.Row="0" Classes="toolbar-frame" Margin="0">
            <StackPanel Orientation="Horizontal" Spacing="6">
                <Button Classes="toolbar-button" Command="{Binding RefreshCommand}">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <Image Source="/Assets/Icons9x/refresh.ico" Classes="icon-small"/>
                        <TextBlock Text="Refresh Inventory" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
                <Button Classes="toolbar-button" Command="{Binding DisableSelectedPluginCommand}">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <Image Source="/Assets/Icons9x/remove.ico" Classes="icon-small"/>
                        <TextBlock Text="Disable Installed" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
                <Button Classes="toolbar-button" Command="{Binding InstallSelectedCandidateCommand}">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <Image Source="/Assets/Icons9x/add.ico" Classes="icon-small"/>
                        <TextBlock Text="Install Candidate" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
            </StackPanel>
        </Border>

        <Border Grid.Row="1" Classes="status-strip" Margin="0">
            <TextBlock Text="Choose a plugin folder, refresh candidates, then install verified DLLs. Disable installed entries to roll back quickly." Classes="helper-text"/>
        </Border>

        <Grid Grid.Row="2" RowDefinitions="Auto,*" RowSpacing="0" Margin="4,0,4,4">
            <Border Classes="group-caption-chip">
                <TextBlock Text="Plugin Source and Inventory" Classes="group-title"/>
            </Border>
            <Border Grid.Row="1" Classes="group-frame" Margin="0,-8,0,0">
                <Grid RowDefinitions="Auto,*,*" RowSpacing="10">
                    <Grid Grid.Row="0" ColumnDefinitions="Auto,*,Auto" ColumnSpacing="8">
                        <TextBlock Grid.Column="0" VerticalAlignment="Center" Text="Plugin directory"/>
                        <TextBox Grid.Column="1" Text="{Binding PluginDirectory}"/>
                        <Button Grid.Column="2" Classes="command-button" Command="{Binding SavePluginDirectoryCommand}">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <Image Source="/Assets/Icons9x/folder.ico" Classes="icon-small"/>
                                <TextBlock Text="Save Directory" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                    </Grid>

                    <Grid Grid.Row="1" RowDefinitions="Auto,*" RowSpacing="6">
                        <TextBlock Grid.Row="0" Text="Installed Plugins" FontWeight="SemiBold"/>
                        <ListBox Grid.Row="1" Classes="list-surface" ItemsSource="{Binding InstalledPlugins}" SelectedItem="{Binding SelectedInstalledPlugin}" DisplayMemberBinding="{Binding DisplayName}"/>
                    </Grid>

                    <Grid Grid.Row="2" RowDefinitions="Auto,*,Auto" RowSpacing="6">
                        <TextBlock Grid.Row="0" Text="Discovered Eligible Plugin DLLs" FontWeight="SemiBold"/>
                        <ListBox Grid.Row="1" Classes="list-surface" ItemsSource="{Binding PluginCandidates}" SelectedItem="{Binding SelectedPluginCandidate}">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Grid ColumnDefinitions="Auto,*" ColumnSpacing="8">
                                        <Image Source="/Assets/Icons9x/plugins.ico" Classes="icon-small" VerticalAlignment="Top" Margin="0,1,0,0"/>
                                        <StackPanel Grid.Column="1">
                                            <TextBlock Text="{Binding DisplayName}" FontWeight="SemiBold"/>
                                            <TextBlock Text="{Binding Path}" Classes="subtle-text" TextWrapping="Wrap"/>
                                        </StackPanel>
                                    </Grid>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>

                        <Grid Grid.Row="2" ColumnDefinitions="*,Auto,Auto" ColumnSpacing="8">
                            <TextBox Grid.Column="0" Watermark="Browse or paste plugin DLL path" Text="{Binding PluginDllPath}"/>
                            <Button Grid.Column="1" Classes="command-button" Click="OnBrowsePluginClick">Browse...</Button>
                            <Button Grid.Column="2" Classes="command-button" Command="{Binding InstallFromPathCommand}">
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <Image Source="/Assets/Icons9x/add.ico" Classes="icon-small"/>
                                    <TextBlock Text="Install From Path" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                        </Grid>
                    </Grid>
                </Grid>
            </Border>
        </Grid>

        <Border Grid.Row="3" Classes="status-strip" Margin="0">
            <TextBlock Text="{Binding Status}" Classes="accent-text"/>
        </Border>
    </Grid>
</UserControl>

