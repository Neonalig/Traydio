<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Traydio.ViewModels"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             x:Name="Root"
             x:Class="Traydio.Views.PluginManagementPage"
             x:DataType="vm:PluginManagementWindowViewModel">
    <Grid Margin="0" RowDefinitions="Auto,*" RowSpacing="6">

        <Border Grid.Row="0" Classes="status-strip" Margin="0">
            <TextBlock Text="Double-click candidates to install and installed entries to disable/enable. Uninstall (or Delete key) removes plugins. If a plugin file is locked, it is marked for delete on restart." Classes="helper-text"/>
        </Border>

        <Grid Grid.Row="1" RowDefinitions="Auto,*" RowSpacing="0" Margin="4,0,4,4">
            <Border Classes="group-caption-chip">
                <TextBlock Text="Plugin Source and Inventory" Classes="group-title"/>
            </Border>
            <Border Grid.Row="1" Classes="group-frame" Margin="0,-8,0,0">
                <Grid RowDefinitions="Auto,Auto,*,Auto,*,Auto" RowSpacing="6">
                    <Grid Grid.Row="0" ColumnDefinitions="Auto,*,Auto,Auto,Auto" ColumnSpacing="8">
                        <TextBlock Grid.Column="0" VerticalAlignment="Center" Text="Plugin install folder"/>
                        <TextBox Grid.Column="1" Classes="input-standard" Text="{Binding PluginDirectory}"/>
                        <Button Grid.Column="2" Classes="command-button" Click="OnChangePluginDirectoryClick">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <Image Source="/Assets/folder.ico" Classes="icon-small"/>
                                <TextBlock Text="Browse..." VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                        <Button Grid.Column="3" Classes="command-button" Command="{Binding RefreshCommand}">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <Image Source="/Assets/refresh.ico" Classes="icon-small"/>
                                <TextBlock Text="Refresh" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                        <Button Grid.Column="4"
                                Classes="command-button"
                                Click="OnRestartAppClick">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <Image Source="/Assets/restart.ico" Classes="icon-small"/>
                                <TextBlock Text="Restart App" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                    </Grid>

                    <TextBlock Grid.Row="1" Text="Installed Plugins" FontWeight="SemiBold"/>
                    <ListBox Grid.Row="2"
                                 x:Name="InstalledPluginsList"
                                 Classes="list-surface plugin-list-surface"
                                 ItemsSource="{Binding InstalledPlugins}"
                                 SelectedItem="{Binding SelectedInstalledPlugin}"
                                 KeyDown="OnInstalledListKeyDown"
                                 DoubleTapped="OnInstalledListDoubleTapped"
                                 DragDrop.AllowDrop="True"
                                 DragDrop.DragOver="OnPluginListDragOver"
                                 DragDrop.Drop="OnInstalledListDrop">
                            <ListBox.ItemTemplate>
                                <DataTemplate x:DataType="vm:PluginManagementWindowViewModel+InstalledPluginItem">
                                    <Border Padding="0,4">
                                        <Grid ColumnDefinitions="Auto,Auto,*,Auto,Auto" ColumnSpacing="8">
                                            <CheckBox Grid.Column="0"
                                                      IsChecked="{Binding IsEnabled}"
                                                      VerticalAlignment="Center"
                                                      Click="OnInstalledCheckboxClick"/>
                                            <Image Grid.Column="1" Source="/Assets/plugins.ico" Classes="icon-small" VerticalAlignment="Top" Margin="0,1,0,0"/>
                                            <StackPanel Grid.Column="2" Spacing="2" IsEnabled="{Binding IsEnabled}">
                                                <TextBlock Text="{Binding DisplayName}" VerticalAlignment="Center"/>
                                                <TextBlock Text="{Binding VersionText, StringFormat='v{0}'}" Classes="subtle-text"/>
                                                <TextBlock Text="Marked for delete on restart"
                                                           Classes="error-text"
                                                           FontWeight="SemiBold"
                                                           IsVisible="{Binding IsPendingDelete}"/>
                                            </StackPanel>
                                            <Button Grid.Column="3"
                                                    Classes="command-button plugin-row-button"
                                                    IsVisible="{Binding HasSettings}"
                                                    IsEnabled="{Binding IsEnabled}"
                                                    Command="{Binding #Root.OpenPluginSettingsCommand}"
                                                    CommandParameter="{Binding}">
                                                <StackPanel Orientation="Horizontal" Spacing="6">
                                                    <Image Source="/Assets/settings.ico" Classes="icon-small"/>
                                                    <TextBlock Text="Settings" VerticalAlignment="Center"/>
                                                </StackPanel>
                                            </Button>
                                            <Button Grid.Column="4"
                                                    Classes="command-button plugin-row-button"
                                                    IsVisible="{Binding !IsPendingDelete}"
                                                    Command="{Binding #Root.RemovePluginCommand}"
                                                    CommandParameter="{Binding}">
                                                <StackPanel Orientation="Horizontal" Spacing="6">
                                                    <Image Source="/Assets/remove.ico" Classes="icon-small"/>
                                                    <TextBlock Text="Uninstall" VerticalAlignment="Center"/>
                                                </StackPanel>
                                            </Button>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                    </ListBox>

                    <TextBlock Grid.Row="3" Text="Discovered Eligible Plugin DLLs" FontWeight="SemiBold"/>
                    <ListBox Grid.Row="4"
                                 x:Name="PluginCandidatesList"
                                 Classes="list-surface plugin-list-surface"
                                 ItemsSource="{Binding PluginCandidates}"
                                 SelectedItem="{Binding SelectedPluginCandidate}"
                                 DoubleTapped="OnCandidateListDoubleTapped"
                                 DragDrop.AllowDrop="True"
                                 DragDrop.DragOver="OnPluginListDragOver"
                                 DragDrop.Drop="OnCandidateListDrop">
                            <ListBox.ItemTemplate>
                                <DataTemplate x:DataType="vm:PluginManagementWindowViewModel+PluginCandidateItem">
                                    <Border Padding="0,4"
                                            Classes="plugin-candidate-entry"
                                            Classes.recommended-candidate="{Binding IsFeatured}">
                                        <Grid ColumnDefinitions="Auto,*,Auto,Auto" ColumnSpacing="8">
                                            <Image Source="/Assets/plugins.ico" Classes="icon-small" VerticalAlignment="Top" Margin="0,1,0,0"/>
                                            <StackPanel Grid.Column="1" Spacing="2">
                                                <StackPanel Orientation="Horizontal" Spacing="8">
                                                    <Border Classes="recommended-badge"
                                                            IsVisible="{Binding IsFeatured}"
                                                            ToolTip.Tip="Featured plugin: this plugin is recommended by the Traydio team for its quality, usefulness, and security.">
                                                        <StackPanel Orientation="Horizontal" Spacing="4">
                                                            <Image Source="/Assets/recommended.ico" Classes="icon-small" Height="12"/>
                                                            <TextBlock Text="Featured" Classes="recommended-badge-text" VerticalAlignment="Center"/>
                                                        </StackPanel>
                                                    </Border>
                                                    <Border Classes="recommended-badge"
                                                            IsVisible="{Binding IsOfficial}"
                                                            ToolTip.Tip="Official plugin: this plugin is developed or officially endorsed by the Traydio team.">
                                                        <StackPanel Orientation="Horizontal" Spacing="4">
                                                            <Image Source="/Assets/keys.ico" Classes="icon-small" Height="12"/>
                                                            <TextBlock Text="Official" Classes="recommended-badge-text" VerticalAlignment="Center"/>
                                                        </StackPanel>
                                                    </Border>
                                                    <Border Classes="recommended-badge"
                                                            IsVisible="{Binding IsExternal}"
                                                            ToolTip.Tip="External plugin: install only if you trust the plugin author and have reviewed the code/source.">
                                                        <StackPanel Orientation="Horizontal" Spacing="4">
                                                            <Image Source="/Assets/info.ico" Classes="icon-small" Height="12"/>
                                                            <TextBlock Text="External" Classes="recommended-badge-text" VerticalAlignment="Center"/>
                                                        </StackPanel>
                                                    </Border>
                                                </StackPanel>
                                                <TextBlock Text="{Binding DisplayName}" FontWeight="SemiBold"/>
                                                <TextBlock Text="{Binding VersionText, StringFormat='v{0}'}" Classes="subtle-text"/>
                                                <TextBlock Text="{Binding InstalledVersionText, StringFormat='Installed v{0}'}" Classes="subtle-text" IsVisible="{Binding HasInstalledVersion}"/>
                                                <TextBlock Text="{Binding Path}" Classes="subtle-text" TextWrapping="Wrap"/>
                                            </StackPanel>
                                            <Button Grid.Column="2"
                                                    Classes="command-button plugin-row-button"
                                                    Command="{Binding #Root.InstallCandidateItemCommand}"
                                                    CommandParameter="{Binding}">
                                                <StackPanel Orientation="Horizontal" Spacing="6">
                                                    <Image Source="/Assets/add.ico" Classes="icon-small"/>
                                                    <TextBlock Text="Install" VerticalAlignment="Center"/>
                                                </StackPanel>
                                            </Button>
                                            <Button Grid.Column="3"
                                                    Classes="command-button plugin-row-button"
                                                    IsVisible="{Binding IsUpgrade}"
                                                    Command="{Binding #Root.UpgradeCandidateItemCommand}"
                                                    CommandParameter="{Binding}">
                                                <StackPanel Orientation="Horizontal" Spacing="6">
                                                    <Image Source="/Assets/add.ico" Classes="icon-small"/>
                                                    <TextBlock Text="Upgrade" VerticalAlignment="Center"/>
                                                </StackPanel>
                                            </Button>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                    </ListBox>

                    <Grid Grid.Row="5" ColumnDefinitions="*,Auto" ColumnSpacing="8">
                        <TextBox Grid.Column="0" Classes="input-standard" Watermark="Browse or paste plugin DLL path" Text="{Binding PluginDllPath}"/>
                        <Button Grid.Column="1" Classes="command-button" Click="OnBrowsePluginClick">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <Image Source="/Assets/folder_with_file.ico" Classes="icon-small"/>
                                <TextBlock Text="Browse..." VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                    </Grid>
                </Grid>
            </Border>
        </Grid>

    </Grid>
</UserControl>

