<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:Traydio.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        x:Class="Traydio.Views.StationSearchWindow"
        x:DataType="vm:StationSearchWindowViewModel"
        Width="980"
        Height="680"
        Title="Traydio - Station Search">

    <Grid Margin="12" RowDefinitions="Auto,Auto,*,Auto" RowSpacing="8">
        <Grid Grid.Row="0" ColumnDefinitions="2*,2*,Auto,Auto,Auto" ColumnSpacing="8">
            <ComboBox Grid.Column="0"
                      ItemsSource="{Binding Providers}"
                      SelectedItem="{Binding SelectedProvider}"
                      DisplayMemberBinding="{Binding DisplayName}"/>
            <TextBox Grid.Column="1" Watermark="Search query" Text="{Binding Query}"/>
            <Button Grid.Column="2" Content="Search" Command="{Binding SearchCommand}"/>
            <TextBox Grid.Column="3" Width="180" Watermark="Filter results" Text="{Binding FilterText}"/>
            <Button Grid.Column="4" Content="Apply Filter" Command="{Binding ApplyFilterCommand}"/>
        </Grid>

        <Grid Grid.Row="1" ColumnDefinitions="*,Auto,Auto" ColumnSpacing="8">
            <TextBox Grid.Column="0" Watermark="External plugin DLL path" Text="{Binding PluginDllPath}"/>
            <Button Grid.Column="1" Content="Add Plugin" Command="{Binding AddPluginFromPathCommand}"/>
            <Button Grid.Column="2" Content="Disable Selected Provider" Command="{Binding RemoveSelectedProviderCommand}"/>
        </Grid>

        <ListBox Grid.Row="2" ItemsSource="{Binding Results}" SelectedItem="{Binding SelectedResult}">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <Grid ColumnDefinitions="3*,5*" ColumnSpacing="8">
                        <StackPanel>
                            <TextBlock Text="{Binding Name}" FontWeight="SemiBold"/>
                            <TextBlock Text="{Binding Country}" Opacity="0.75"/>
                        </StackPanel>
                        <StackPanel Grid.Column="1">
                            <TextBlock Text="{Binding StreamUrl}" TextWrapping="Wrap"/>
                            <TextBlock Text="{Binding Description}" Opacity="0.75" TextWrapping="Wrap"/>
                        </StackPanel>
                    </Grid>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

        <Grid Grid.Row="3" ColumnDefinitions="Auto,*" ColumnSpacing="8">
            <Button Grid.Column="0" Content="Add Selected Station" Command="{Binding AddSelectedStationCommand}"/>
            <TextBlock Grid.Column="1" VerticalAlignment="Center" Text="{Binding Status}"/>
        </Grid>
    </Grid>
</Window>

