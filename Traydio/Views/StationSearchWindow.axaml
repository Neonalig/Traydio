<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Traydio.ViewModels"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             x:Name="Root"
             x:Class="Traydio.Views.StationSearchPage"
             x:DataType="vm:StationSearchWindowViewModel">

    <UserControl.KeyBindings>
        <KeyBinding Gesture="Enter" Command="{Binding SearchCommand}" />
    </UserControl.KeyBindings>

    <Grid Margin="0">
        <Grid IsEnabled="{Binding !IsBusy}" RowDefinitions="Auto,Auto,*" RowSpacing="6">
            <Border Grid.Row="0" Classes="toolbar-frame" Margin="0">
                <Grid RowDefinitions="Auto,Auto,Auto,Auto" RowSpacing="8">
                <Grid Grid.Row="0" ColumnDefinitions="84,2.4*,*" ColumnSpacing="8">
                    <TextBlock Grid.Column="0" Text="Provider" VerticalAlignment="Center"/>
                    <ComboBox Grid.Column="1"
                              ItemsSource="{Binding Providers}"
                              SelectedItem="{Binding SelectedProvider}"
                              DisplayMemberBinding="{Binding DisplayName}"/>
                    <Button Grid.Column="2"
                            HorizontalAlignment="Right"
                            Click="OnOpenProviderWebsiteClick"
                            IsVisible="{Binding HasSelectedProviderWebsiteUrl}"
                            Background="Transparent"
                            BorderThickness="0"
                            Padding="0">
                        <TextBlock Text="{Binding ProviderWebsiteHostText}"
                                   Foreground="DodgerBlue"
                                   TextDecorations="Underline"/>
                    </Button>
                </Grid>

                <Grid Grid.Row="1" ColumnDefinitions="84,1.2*,84,2.8*,Auto" ColumnSpacing="8">
                    <TextBlock Grid.Column="0" Text="View" VerticalAlignment="Center"/>
                    <ComboBox Grid.Column="1"
                              ItemsSource="{Binding SearchModes}"
                              SelectedItem="{Binding SelectedSearchMode}"
                              DisplayMemberBinding="{Binding DisplayName}"
                              IsEnabled="{Binding IsSearchModeEditable}"/>
                    <TextBlock Grid.Column="2" Text="Query" VerticalAlignment="Center"/>
                    <TextBox Grid.Column="3" Classes="input-standard" Watermark="Search query" Text="{Binding Query}"/>
                    <Button Grid.Column="4" Classes="command-button" Command="{Binding SearchCommand}">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <Image Source="/Assets/search.ico" Classes="icon-small"/>
                            <TextBlock Text="Search" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </Grid>

                <Grid Grid.Row="2" ColumnDefinitions="84,*,84,*,84,*,84,*,84,*,Auto,Auto" ColumnSpacing="8">
                    <TextBlock Grid.Column="0" Text="Country" VerticalAlignment="Center"/>
                    <ComboBox Grid.Column="1"
                              ItemsSource="{Binding CountryOptions}"
                              SelectedItem="{Binding SelectedCountry}"
                              DisplayMemberBinding="{Binding DisplayName}"
                              IsEnabled="{Binding SupportsCountryFilter}"/>

                    <TextBlock Grid.Column="2" Text="Genre" VerticalAlignment="Center"/>
                    <TextBox Grid.Column="3" Classes="input-standard" Watermark="style" Text="{Binding GenreFilter}" IsEnabled="{Binding SupportsGenreFilter}"/>

                    <TextBlock Grid.Column="4" Text="Language" VerticalAlignment="Center"/>
                    <ComboBox Grid.Column="5"
                              ItemsSource="{Binding LanguageOptions}"
                              SelectedItem="{Binding SelectedLanguage}"
                              DisplayMemberBinding="{Binding DisplayName}"
                              IsEnabled="{Binding SupportsLanguageFilter}"/>

                    <TextBlock Grid.Column="6" Text="Order" VerticalAlignment="Center"/>
                    <TextBox Grid.Column="7" Classes="input-standard" Watermark="top/big/med/sma" Text="{Binding OrderFilter}" IsEnabled="{Binding SupportsOrderFilter}"/>

                    <TextBox Grid.Column="8" Classes="input-standard" Watermark="Filter results" Text="{Binding FilterText}"/>
                    <CheckBox Grid.Column="9"
                              VerticalAlignment="Center"
                              Content="Prefer high quality"
                              IsChecked="{Binding PreferHighQuality}"
                              IsEnabled="{Binding SupportsHighQualityPreference}"/>
                    <Button Grid.Column="10" Classes="command-button" Command="{Binding ApplyFilterCommand}">
                        <TextBlock Text="Apply" VerticalAlignment="Center"/>
                    </Button>
                    <Button Grid.Column="11" Classes="command-button" Command="{Binding ResetAdvancedFiltersCommand}">
                        <TextBlock Text="Reset" VerticalAlignment="Center"/>
                    </Button>
                </Grid>

                <ContentControl Grid.Row="3"
                                IsVisible="{Binding HasProviderSearchSettings}"
                                Content="{Binding ProviderSearchSettingsView}"/>
                </Grid>
            </Border>

            <Border Grid.Row="1" Classes="status-strip" Margin="0">
                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="10">
                <TextBlock Grid.Column="0"
                           Text="{Binding Status}"
                           Classes="helper-text"
                           TextTrimming="CharacterEllipsis"
                           VerticalAlignment="Center"/>
                <TextBlock Grid.Column="1"
                           Text="Entering query text locks View to Search until query is cleared."
                           Classes="helper-text"
                           VerticalAlignment="Center"/>
                </Grid>
            </Border>

            <Grid Grid.Row="2" RowDefinitions="Auto,*" RowSpacing="0" Margin="4,0,4,4">
                <Border Classes="group-caption-chip">
                    <TextBlock Text="Search Results" Classes="group-title"/>
                </Border>
                <Border Grid.Row="1" Classes="group-frame" Margin="0,-8,0,0">
                    <Grid RowDefinitions="*,Auto" RowSpacing="8">
                        <ListBox x:Name="ResultsList"
                                 Grid.Row="0"
                                 Classes="list-surface"
                                 ItemsSource="{Binding Results}"
                                 SelectedItem="{Binding SelectedResult}"
                                 ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Grid ColumnDefinitions="Auto,3*,5*,Auto" ColumnSpacing="8">
                                        <Grid.ContextMenu>
                                            <ContextMenu>
                                                <MenuItem Header="Copy Station Name" Click="OnCopyResultNameClick"/>
                                                <MenuItem Header="Copy Stream URL" Click="OnCopyResultUrlClick"/>
                                                <MenuItem Header="Copy Name + URL" Click="OnCopyResultNameUrlClick"/>
                                            </ContextMenu>
                                        </Grid.ContextMenu>
                                        <Image Source="/Assets/stations.ico" Classes="icon-small" VerticalAlignment="Top" Margin="0,1,0,0"/>
                                        <StackPanel Grid.Column="1" MaxWidth="320">
                                            <TextBlock Text="{Binding Name}"
                                                       FontWeight="SemiBold"
                                                       TextWrapping="WrapWithOverflow"
                                                       ToolTip.Tip="{Binding Name}"/>
                                            <TextBlock Text="{Binding Country}"
                                                       Classes="subtle-text"
                                                       TextWrapping="WrapWithOverflow"
                                                       ToolTip.Tip="{Binding Country}"/>
                                        </StackPanel>
                                        <StackPanel Grid.Column="2" MaxWidth="640">
                                            <TextBlock Text="{Binding StreamUrl}"
                                                       TextWrapping="WrapWithOverflow"
                                                       ToolTip.Tip="{Binding StreamUrl}"/>
                                            <TextBlock Text="{Binding Description}"
                                                       Classes="subtle-text"
                                                       TextWrapping="WrapWithOverflow"
                                                       ToolTip.Tip="{Binding Description}"/>
                                        </StackPanel>
                                        <Button Grid.Column="3"
                                                Classes="command-button"
                                                VerticalAlignment="Center"
                                                Click="OnAddResultClick">
                                            <StackPanel Orientation="Horizontal" Spacing="6">
                                                <Image Source="/Assets/add.ico" Classes="icon-small"/>
                                                <TextBlock Text="Add" VerticalAlignment="Center"/>
                                            </StackPanel>
                                        </Button>
                                    </Grid>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>

                        <Grid Grid.Row="1" ColumnDefinitions="*,Auto,*" ColumnSpacing="8" Margin="0,4,0,0" IsVisible="{Binding SupportsPagination}">
                            <Border Grid.Column="0"/>
                            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="6" HorizontalAlignment="Center" VerticalAlignment="Center">
                                <Button Classes="command-button"
                                        Width="34"
                                        Height="34"
                                        MinWidth="34"
                                        MaxWidth="34"
                                        MinHeight="34"
                                        MaxHeight="34"
                                        Padding="0"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        Command="{Binding FirstPageCommand}"
                                        IsVisible="{Binding CanGoToFirstPage}">
                                    <TextBlock Text="&lt;&lt;" HorizontalAlignment="Center"/>
                                </Button>
                                <Button Classes="command-button"
                                        Width="34"
                                        Height="34"
                                        MinWidth="34"
                                        MaxWidth="34"
                                        MinHeight="34"
                                        MaxHeight="34"
                                        Padding="0"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        Command="{Binding PreviousPageCommand}"
                                        IsEnabled="{Binding HasPreviousPage}">
                                    <TextBlock Text="&lt;" HorizontalAlignment="Center"/>
                                </Button>
                                <TextBlock Text="{Binding PaginationText}" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                <Button Classes="command-button"
                                        Width="34"
                                        Height="34"
                                        MinWidth="34"
                                        MaxWidth="34"
                                        MinHeight="34"
                                        MaxHeight="34"
                                        Padding="0"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        Command="{Binding NextPageCommand}"
                                        IsEnabled="{Binding HasNextPage}">
                                    <TextBlock Text="&gt;" HorizontalAlignment="Center"/>
                                </Button>
                                <Button Classes="command-button"
                                        Width="34"
                                        Height="34"
                                        MinWidth="34"
                                        MaxWidth="34"
                                        MinHeight="34"
                                        MaxHeight="34"
                                        Padding="0"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        Command="{Binding LastPageCommand}"
                                        IsVisible="{Binding CanGoToLastPage}">
                                    <TextBlock Text="&gt;&gt;" HorizontalAlignment="Center"/>
                                </Button>
                            </StackPanel>
                            <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="6" HorizontalAlignment="Right" VerticalAlignment="Center">
                                <TextBlock Text="Items per page" VerticalAlignment="Center"/>
                                <ComboBox Width="96"
                                          ItemsSource="{Binding PageSizePresetOptions}"
                                          SelectedItem="{Binding PageSize}"/>
                            </StackPanel>
                        </Grid>
                    </Grid>
                </Border>
            </Grid>
        </Grid>

        <Border IsVisible="{Binding IsBusy}" Background="{DynamicResource OverlayBackgroundBrush}">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="8">
                <ProgressBar Width="220" IsIndeterminate="True"/>
                <TextBlock Text="{Binding Status}" Classes="helper-text" HorizontalAlignment="Center"/>
                <Button Classes="command-button" Command="{Binding CancelSearchCommand}">
                    <TextBlock Text="Cancel" VerticalAlignment="Center"/>
                </Button>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>

