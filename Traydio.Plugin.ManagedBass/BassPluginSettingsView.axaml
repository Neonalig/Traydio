<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="Traydio.Plugin.ManagedBass.BassPluginSettingsView">
    <Grid Margin="12" RowDefinitions="Auto,Auto,Auto,Auto,Auto,*" RowSpacing="10">
        <TextBlock Grid.Row="0" Text="ManagedBass Runtime" FontSize="18" FontWeight="SemiBold"/>

        <TextBlock Grid.Row="1"
                   Text="Choose a folder for BASS native files. Download bass.dll, bassopus.dll, and tags.dll for your current architecture. tags.dll enables metadata parsing."
                   TextWrapping="Wrap"/>

        <Grid Grid.Row="2" ColumnDefinitions="Auto,*,Auto,Auto" ColumnSpacing="8">
            <TextBlock Grid.Column="0" VerticalAlignment="Center" Text="Native folder"/>
            <TextBox x:Name="FolderPathBox" Grid.Column="1" Watermark="C:\\Tools\\BASS"/>
            <Button Grid.Column="2" Click="OnBrowseClick">Browse...</Button>
            <Button Grid.Column="3" Click="OnSavePathClick">Save Path</Button>
        </Grid>

        <Grid Grid.Row="3" ColumnDefinitions="Auto,*,Auto" ColumnSpacing="8">
            <TextBlock Grid.Column="0" VerticalAlignment="Center" Text="Output device index"/>
            <ComboBox x:Name="OutputDeviceComboBox" Grid.Column="1"/>
            <Button Grid.Column="2" Click="OnSaveOutputDeviceClick">Save Output</Button>
        </Grid>

        <StackPanel Grid.Row="4" Orientation="Horizontal" Spacing="8">
            <Button Click="OnDownloadClick">Download bass.dll</Button>
            <Button Click="OnDownloadBassOpusClick">Download bassopus.dll</Button>
            <Button Click="OnDownloadBassTagsClick">Download tags.dll</Button>
            <TextBlock x:Name="StatusText" VerticalAlignment="Center" TextWrapping="Wrap"/>
        </StackPanel>
    </Grid>
</UserControl>

