<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="Traydio.Plugin.LibVlc.LibVlcPluginSettingsView">

    <Grid Margin="12" RowDefinitions="Auto,Auto,Auto,Auto,*,Auto,Auto,Auto" RowSpacing="10">
        <TextBlock Grid.Row="0" Text="LibVLC Output Settings" FontSize="18" FontWeight="SemiBold"/>

        <TextBlock Grid.Row="1"
                   Text="Leave fields blank to use system defaults. Module examples on Windows include mmdevice, directsound, and waveout."
                   TextWrapping="Wrap"/>

        <Grid Grid.Row="2" ColumnDefinitions="Auto,*" ColumnSpacing="8">
            <TextBlock Grid.Column="0" VerticalAlignment="Center" Text="Output module"/>
            <ComboBox x:Name="OutputModuleComboBox" Grid.Column="1"/>
        </Grid>

        <Grid Grid.Row="3" ColumnDefinitions="Auto,*" ColumnSpacing="8">
            <TextBlock Grid.Column="0" VerticalAlignment="Center" Text="Output device"/>
            <ComboBox x:Name="OutputDeviceComboBox" Grid.Column="1"/>
        </Grid>

        <Button Grid.Row="5"
                x:Name="WebsiteLinkButton"
                Click="OnOpenWebsiteClick"
                HorizontalAlignment="Center"
                Background="Transparent"
                BorderThickness="0"
                Padding="0">
            <TextBlock Text="Open videolan.org"
                       Foreground="DodgerBlue"
                       TextDecorations="Underline"/>
        </Button>

        <StackPanel Grid.Row="6" Spacing="6" HorizontalAlignment="Center">
            <TextBlock Text="Copyright (C) VideoLAN and LibVLC contributors."
                       Foreground="Gray"
                       TextWrapping="Wrap"
                       HorizontalAlignment="Center"/>
            <Button Content="View disclaimer information"
                    HorizontalAlignment="Center"
                    Click="OnShowDisclaimerClick"/>
        </StackPanel>

        <TextBlock Grid.Row="7" x:Name="StatusText" Foreground="{DynamicResource StatusAccentBrush}" TextWrapping="Wrap"/>
    </Grid>
</UserControl>

